<script src="{{ 'back-in-stock.js' | asset_url }}" defer></script>

{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- if current_variant.available == false -%}
  <div class="back-in-stock-container" style="margin-top: 15px; margin-bottom: 15px;">
    <form id="back-in-stock-form">
      <!-- Hidden fields to pass data to our JavaScript -->
      <input type="hidden" id="bis-product-id" value="{{ product.id }}">
      <input type="hidden" id="bis-variant-id" value="{{ current_variant.id }}">
      <input type="hidden" id="bis-product-name" value="{{ product.title }}">

      <div style="display: flex; flex-direction: column; gap: 10px;">
        <input 
          type="email" 
          id="bis-email" 
          placeholder="Enter your email address" 
          required
          style="padding: 12px; width: 100%; border: 1px solid #ccc; border-radius: 4px; font-size: 16px; box-sizing: border-box;"
        >
        <button type="submit" style="width: 100%; padding: 14px; background-color: #0061FF; color: white; border: none; border-radius: 4px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background-color 0.2s;">
          Notify Me When Available
        </button>
      </div>
    </form>
    <p id="bis-message" style="display:none; margin-top: 10px; font-weight: bold; font-size: 14px; text-align: center;"></p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Back In Stock Button",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}